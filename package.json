{
    "private": true,
    "name": "firefly",
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "lint": "pnpm --filter firefly-fe run lint",
        "build": "pnpm --filter firefly-fe run build",
        "test:run": "pnpm --filter firefly-fe run test:run",
        "test:coverage": "pnpm --filter firefly-fe run test:coverage",
        "test:integration": "echo test:integration: run via docker compose in CI",
        "test:e2e": "echo test:e2e: not yet configured",
        "check:trace": "node scripts/check-traceability.mjs",
        "check:trajectory": "node scripts/check-trajectory.mjs",
        "check:coverage": "node scripts/check-coverage-ratchet.mjs",
        "check:eval": "node scripts/check-eval-ratchet.mjs",
        "check:recordings": "node scripts/check-recordings.mjs",
        "check:a11y": "node scripts/check-a11y.mjs",
        "gate:status": "node scripts/gate-status.mjs",
        "qa:verify": "node scripts/qa-verify.mjs",
        "qa:record-demos": "node scripts/record-demos.mjs",
        "qa:record-proof": "node scripts/record-demos.mjs --proof"
    },
    "devDependencies": {
        "typescript": "^6.0.3"
    }
}